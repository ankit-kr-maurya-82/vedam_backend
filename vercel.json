{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "src/index.js": {
      "maxDuration": 30,
      "bodyParser": {
        "sizeLimit": "25mb"
      }
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ]
}
