# Backend environment variables
# Copy this file to .env and replace the placeholder values.

ACCESS_TOKEN_EXPIRY=5d
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
BASE_URL=https://your-backend-domain.vercel.app
CLIENT_URL=https://your-frontend-domain.vercel.app
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.vercel.app
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
PORT=8000
REFRESH_TOKEN_EXPIRY=10d
REFRESH_TOKEN_SECRET=replace_with_a_second_long_random_secret
WEB_PUSH_PUBLIC_KEY=replace_with_vapid_public_key
WEB_PUSH_PRIVATE_KEY=replace_with_vapid_private_key
WEB_PUSH_SUBJECT=mailto:your-email@example.com
